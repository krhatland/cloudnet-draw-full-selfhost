{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.1.0.0",
  "metadata": {
    "description": "Deploys CloudNet Draw as an Azure Functions Flex Consumption app with managed identity, storage-backed output, and optional Confluence export.",
    "author": "Codex",
    "source": "https://github.com/krhatland/cloudnet-draw-full-selfhost"
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Deployment location. Flex Consumption support is region-specific."
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique name of the Azure Function App."
      }
    },
    "hostingPlanName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional hosting plan name. When empty, a name is derived from the function app."
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the storage account used for Azure Functions host state and generated artifacts."
      }
    },
    "resourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group containing the selected storage account."
      }
    },
    "storageAccountSkuName": {
      "type": "string",
      "defaultValue": "Standard_LRS",
      "allowedValues": [
        "Standard_LRS",
        "Standard_ZRS",
        "Standard_GRS",
        "Standard_RAGRS"
      ],
      "metadata": {
        "description": "Storage redundancy option for newly created storage accounts."
      }
    },
    "storageAccountKind": {
      "type": "string",
      "defaultValue": "StorageV2",
      "allowedValues": [
        "StorageV2"
      ],
      "metadata": {
        "description": "Storage account kind. StorageV2 is required for this solution."
      }
    },
    "newOrExisting": {
      "type": "string",
      "defaultValue": "new",
      "allowedValues": [
        "new",
        "existing"
      ],
      "metadata": {
        "description": "Indicates whether the selected storage account should be created or reused."
      }
    },
    "containerName": {
      "type": "string",
      "defaultValue": "drawfunc",
      "metadata": {
        "description": "Blob container name used for generated topology and diagram output."
      }
    },
    "deploymentContainerName": {
      "type": "string",
      "defaultValue": "functionpackage",
      "metadata": {
        "description": "Blob container used internally by Flex Consumption deployment settings."
      }
    },
    "instanceMemoryMB": {
      "type": "int",
      "defaultValue": 2048,
      "allowedValues": [
        512,
        2048,
        4096
      ],
      "metadata": {
        "description": "Memory allocated per Flex Consumption instance."
      }
    },
    "maximumInstanceCount": {
      "type": "int",
      "defaultValue": 40,
      "metadata": {
        "description": "Maximum number of Flex Consumption instances."
      }
    },
    "runtimeName": {
      "type": "string",
      "defaultValue": "python",
      "allowedValues": [
        "python"
      ],
      "metadata": {
        "description": "Azure Functions worker runtime."
      }
    },
    "runtimeVersion": {
      "type": "string",
      "defaultValue": "3.12",
      "allowedValues": [
        "3.11",
        "3.12"
      ],
      "metadata": {
        "description": "Azure Functions runtime version for Python."
      }
    },
    "selectedSubscriptionIds": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Subscription IDs that CloudNet Draw should query."
      }
    },
    "grantReaderToSelectedSubscriptions": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When true, assigns the Reader role to the function managed identity on each selected subscription."
      }
    },
    "outputMode": {
      "type": "string",
      "defaultValue": "storage",
      "allowedValues": [
        "storage",
        "confluence"
      ],
      "metadata": {
        "description": "Select whether output is only stored in Azure Blob Storage or also exported to Confluence."
      }
    },
    "confluenceBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Base URL of the Confluence site. Leave empty for storage-only deployments."
      }
    },
    "confluenceUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Confluence username or email used for API authentication."
      }
    },
    "confluenceApiToken": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "description": "Confluence API token used for API authentication."
      }
    },
    "confluencePageId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Target Confluence page ID that will receive attachments."
      }
    },
    "confluenceAttachmentPrefix": {
      "type": "string",
      "defaultValue": "cloudnetdraw-topology",
      "metadata": {
        "description": "Filename prefix used for Confluence attachments."
      }
    },
    "applicationInsightsName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Application Insights name. When empty, a name is derived from the function app."
      }
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Log Analytics workspace name. When empty, a name is derived from the function app."
      }
    },
    "_artifactsLocation": {
      "type": "string",
      "defaultValue": "[deployment().properties.templateLink.uri]",
      "metadata": {
        "description": "Base URI where deployment artifacts are staged."
      }
    },
    "_artifactsLocationSasToken": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "description": "Optional SAS token used to access staged deployment artifacts."
      }
    }
  },
  "variables": {
    "hostingPlanName": "[if(empty(parameters('hostingPlanName')), format('{0}-plan', parameters('functionAppName')), parameters('hostingPlanName'))]",
    "applicationInsightsName": "[if(empty(parameters('applicationInsightsName')), format('{0}-appi', parameters('functionAppName')), parameters('applicationInsightsName'))]",
    "logAnalyticsWorkspaceName": "[if(empty(parameters('logAnalyticsWorkspaceName')), format('{0}-law', parameters('functionAppName')), parameters('logAnalyticsWorkspaceName'))]",
    "storageAccountResourceId": "[resourceId(parameters('resourceGroup'), 'Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
    "functionAppResourceId": "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]",
    "hostingPlanResourceId": "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
    "logAnalyticsWorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]",
    "applicationInsightsResourceId": "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]",
    "storageDnsSuffix": "[environment().suffixes.storage]",
    "functionPackageBaseUri": "[uri(parameters('_artifactsLocation'), 'artifacts/function.zip')]",
    "functionPackageUri": "[if(empty(parameters('_artifactsLocationSasToken')), variables('functionPackageBaseUri'), concat(variables('functionPackageBaseUri'), parameters('_artifactsLocationSasToken')))]",
    "deploymentStorageContainerUri": "[uri(format('https://{0}.blob.{1}/', parameters('storageAccountName'), variables('storageDnsSuffix')), parameters('deploymentContainerName'))]",
    "storageBlobDataContributorRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ba92f5b4-2d11-453d-a403-e96b0029c9fe')]",
    "readerRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]",
    "helpers": {
      "storageBlobServiceDefaultName": "[format('{0}/default', parameters('storageAccountName'))]",
      "outputContainerFullName": "[format('{0}/default/{1}', parameters('storageAccountName'), parameters('containerName'))]",
      "deploymentContainerFullName": "[format('{0}/default/{1}', parameters('storageAccountName'), parameters('deploymentContainerName'))]",
      "runtimeLabel": "[format('{0} {1}', parameters('runtimeName'), parameters('runtimeVersion'))]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2020-06-01",
      "name": "pid-9116fcab-e4b1-49ee-9805-3189128df2bf-partnercenter",
      "properties": {
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "resources": []
        }
      }
    },
    {
      "condition": "[equals(parameters('newOrExisting'), 'new')]",
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('storageAccountSkuName')]"
      },
      "kind": "[parameters('storageAccountKind')]",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true,
        "allowSharedKeyAccess": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[variables('helpers').storageBlobServiceDefaultName]",
      "dependsOn": [
        "[variables('storageAccountResourceId')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[variables('helpers').outputContainerFullName]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[variables('helpers').deploymentContainerFullName]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('applicationInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "dependsOn": [
        "[variables('logAnalyticsWorkspaceResourceId')]"
      ],
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[variables('logAnalyticsWorkspaceResourceId')]"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('hostingPlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "tier": "FlexConsumption",
        "name": "FC1"
      },
      "kind": "functionapp",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[variables('hostingPlanResourceId')]",
        "[variables('applicationInsightsResourceId')]",
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', parameters('storageAccountName'), 'default', parameters('deploymentContainerName'))]"
      ],
      "properties": {
        "serverFarmId": "[variables('hostingPlanResourceId')]",
        "httpsOnly": true,
        "functionAppConfig": {
          "deployment": {
            "storage": {
              "type": "blobContainer",
              "value": "[variables('deploymentStorageContainerUri')]",
              "authentication": {
                "type": "SystemAssignedIdentity"
              }
            }
          },
          "runtime": {
            "name": "[parameters('runtimeName')]",
            "version": "[parameters('runtimeVersion')]"
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": "[parameters('maximumInstanceCount')]",
            "instanceMemoryMB": "[parameters('instanceMemoryMB')]"
          }
        },
        "siteConfig": {
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[parameters('storageAccountName')]"
            },
            {
              "name": "AzureWebJobsStorage__credential",
              "value": "managedidentity"
            },
            {
              "name": "DRAWING_STORAGE_URL",
              "value": "[format('https://{0}.blob.{1}', parameters('storageAccountName'), variables('storageDnsSuffix'))]"
            },
            {
              "name": "DRAWING_CONTAINER_NAME",
              "value": "[parameters('containerName')]"
            },
            {
              "name": "OUTPUT_MODE",
              "value": "[parameters('outputMode')]"
            },
            {
              "name": "SELECTED_SUBSCRIPTION_IDS",
              "value": "[string(parameters('selectedSubscriptionIds'))]"
            },
            {
              "name": "CONFLUENCE_BASE_URL",
              "value": "[parameters('confluenceBaseUrl')]"
            },
            {
              "name": "CONFLUENCE_USERNAME",
              "value": "[parameters('confluenceUsername')]"
            },
            {
              "name": "CONFLUENCE_API_TOKEN",
              "value": "[parameters('confluenceApiToken')]"
            },
            {
              "name": "CONFLUENCE_PAGE_ID",
              "value": "[parameters('confluencePageId')]"
            },
            {
              "name": "CONFLUENCE_ATTACHMENT_PREFIX",
              "value": "[parameters('confluenceAttachmentPrefix')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(variables('applicationInsightsResourceId'), '2020-02-02').ConnectionString]"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('storageAccountResourceId'), variables('functionAppResourceId'), 'storage-blob-data-contributor')]",
      "scope": "[variables('storageAccountResourceId')]",
      "dependsOn": [
        "[variables('functionAppResourceId')]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('storageBlobDataContributorRoleDefinitionId')]",
        "principalId": "[reference(variables('functionAppResourceId'), '2023-12-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "condition": "[and(parameters('grantReaderToSelectedSubscriptions'), greater(length(parameters('selectedSubscriptionIds')), 0))]",
      "copy": {
        "name": "selectedSubscriptionReaderAssignments",
        "count": "[length(parameters('selectedSubscriptionIds'))]"
      },
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "[format('grant-reader-sub-{0}', replace(parameters('selectedSubscriptionIds')[copyIndex('selectedSubscriptionReaderAssignments')], '-', ''))]",
      "subscriptionId": "[parameters('selectedSubscriptionIds')[copyIndex('selectedSubscriptionReaderAssignments')]]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[variables('functionAppResourceId')]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "parameters": {
          "principalId": {
            "value": "[reference(variables('functionAppResourceId'), '2023-12-01', 'Full').identity.principalId]"
          },
          "targetSubscriptionId": {
            "value": "[parameters('selectedSubscriptionIds')[copyIndex('selectedSubscriptionReaderAssignments')]]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "principalId": {
              "type": "string"
            },
            "targetSubscriptionId": {
              "type": "string"
            }
          },
          "variables": {
            "readerRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]"
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(parameters('targetSubscriptionId'), parameters('principalId'), 'cloudnetdraw-reader')]",
              "properties": {
                "roleDefinitionId": "[variables('readerRoleDefinitionId')]",
                "principalId": "[parameters('principalId')]",
                "principalType": "ServicePrincipal"
              }
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2020-10-01",
      "name": "waitForBlobRbacPropagation",
      "location": "[parameters('location')]",
      "kind": "AzurePowerShell",
      "dependsOn": [
        "[guid(variables('storageAccountResourceId'), variables('functionAppResourceId'), 'storage-blob-data-contributor')]"
      ],
      "properties": {
        "azPowerShellVersion": "11.4",
        "scriptContent": "Start-Sleep -Seconds 30",
        "retentionInterval": "PT1H",
        "cleanupPreference": "Always"
      }
    },
    {
      "type": "Microsoft.Web/sites/extensions",
      "apiVersion": "2022-09-01",
      "name": "[format('{0}/{1}', parameters('functionAppName'), 'onedeploy')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deploymentScripts', 'waitForBlobRbacPropagation')]"
      ],
      "properties": {
        "packageUri": "[variables('functionPackageUri')]",
        "remoteBuild": true
      }
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "hostingPlanName": {
      "type": "string",
      "value": "[variables('hostingPlanName')]"
    },
    "functionAppEndpoint": {
      "type": "string",
      "value": "[format('https://{0}', reference(variables('functionAppResourceId')).defaultHostName)]"
    },
    "storageContainerUrl": {
      "type": "string",
      "value": "[uri(format('https://{0}.blob.{1}/', parameters('storageAccountName'), variables('storageDnsSuffix')), parameters('containerName'))]"
    },
    "applicationInsightsName": {
      "type": "string",
      "value": "[variables('applicationInsightsName')]"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "value": "[variables('logAnalyticsWorkspaceName')]"
    },
    "runtime": {
      "type": "string",
      "value": "[variables('helpers').runtimeLabel]"
    },
    "outputMode": {
      "type": "string",
      "value": "[parameters('outputMode')]"
    },
    "selectedSubscriptionCount": {
      "type": "int",
      "value": "[length(parameters('selectedSubscriptionIds'))]"
    }
  }
}
