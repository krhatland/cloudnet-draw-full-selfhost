{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "version": "0.1.2-preview",
  "handler": "Microsoft.Azure.CreateUIDef",
  "parameters": {
    "config": {
      "basics": {
        "location": {
          "label": "Region",
          "toolTip": "Select the Azure region for deployment. Flex Consumption availability is region-specific.",
          "resourceTypes": [
            "Microsoft.Web/sites",
            "Microsoft.Storage/storageAccounts",
            "Microsoft.OperationalInsights/workspaces",
            "Microsoft.Insights/components"
          ]
        }
      }
    },
    "basics": [
    ],
    "steps": [
      {
        "name": "deployment",
        "label": "Deployment",
        "elements": [
          {
            "name": "intro",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "Info",
              "text": "This package deploys CloudNet Draw on Azure Functions Flex Consumption and stores output in Blob Storage before exporting attachments to Confluence."
            }
          },
          {
            "name": "functionAppName",
            "type": "Microsoft.Common.TextBox",
            "label": "Function App Name",
            "toolTip": "Enter a globally unique name for the Azure Function App.",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[a-z0-9-]{2,60}$",
                  "message": "Use 2-60 lowercase letters, numbers, or hyphens."
                }
              ]
            }
          },
          {
            "name": "storageAccount",
            "type": "Microsoft.Storage.StorageAccountSelector",
            "label": "Storage Account",
            "toolTip": "Create a new storage account or choose an existing one in the same resource group and location.",
            "defaultValue": {
              "name": "cloudnetdrawsa01",
              "type": "Standard_LRS"
            },
            "constraints": {
              "allowedTypes": [
                "Standard_LRS",
                "Standard_ZRS",
                "Standard_GRS",
                "Standard_RAGRS"
              ]
            },
            "options": {
              "hideExisting": false
            }
          },
          {
            "name": "containerName",
            "type": "Microsoft.Common.TextBox",
            "label": "Output Container Name",
            "defaultValue": "drawfunc",
            "toolTip": "Blob container used for topology JSON and Draw.io diagram output.",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[a-z0-9](?:[a-z0-9-]{1,61}[a-z0-9])?$",
                  "message": "Use a valid blob container name."
                }
              ]
            }
          }
        ]
      },
      {
        "name": "scale",
        "label": "Scale",
        "elements": [
          {
            "name": "instanceMemoryMB",
            "type": "Microsoft.Common.DropDown",
            "label": "Instance Memory",
            "defaultValue": "2048 MB",
            "toolTip": "Choose the memory size for each Flex Consumption instance.",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "512 MB",
                  "value": 512
                },
                {
                  "label": "2048 MB",
                  "value": 2048
                },
                {
                  "label": "4096 MB",
                  "value": 4096
                }
              ]
            }
          },
          {
            "name": "maximumInstanceCount",
            "type": "Microsoft.Common.DropDown",
            "label": "Maximum Instance Count",
            "defaultValue": "40 instances",
            "toolTip": "Caps how far the Flex Consumption app can scale out.",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "10 instances",
                  "value": 10
                },
                {
                  "label": "20 instances",
                  "value": 20
                },
                {
                  "label": "40 instances",
                  "value": 40
                },
                {
                  "label": "100 instances",
                  "value": 100
                }
              ]
            }
          },
          {
            "name": "runtimeVersion",
            "type": "Microsoft.Common.DropDown",
            "label": "Python Version",
            "defaultValue": "Python 3.12",
            "toolTip": "Choose the Python runtime version for the Function App.",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Python 3.12",
                  "value": "3.12"
                },
                {
                  "label": "Python 3.11",
                  "value": "3.11"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "access",
        "label": "Azure Access",
        "elements": [
          {
            "name": "accessIntro",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "Info",
              "text": "Choose which subscriptions CloudNet Draw should query. The list below is populated from the subscriptions you can currently see in Azure."
            }
          },
          {
            "name": "accessWarning",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "Warning",
              "text": "If you leave automatic Reader assignment enabled, the deploying account must be allowed to create role assignments on every selected subscription."
            }
          },
          {
            "name": "subscriptionsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "/subscriptions?api-version=2022-12-01"
            }
          },
          {
            "name": "selectedSubscriptionIds",
            "type": "Microsoft.Common.DropDown",
            "label": "Subscriptions To Query",
            "toolTip": "Select one or more subscriptions that the function should scan.",
            "multiselect": true,
            "selectAll": true,
            "filter": true,
            "filterPlaceholder": "Filter subscriptions ...",
            "multiLine": true,
            "constraints": {
              "allowedValues": "[map(filter(steps('access').subscriptionsApi.value, (item) => equals(item.state, 'Enabled')), (item) => parse(concat('{\"label\":\"', item.displayName, ' (', item.subscriptionId, ')\",\"description\":\"State: ', item.state, '\",\"value\":\"', item.subscriptionId, '\"}')))]",
              "required": true
            }
          },
          {
            "name": "grantReaderToSelectedSubscriptions",
            "type": "Microsoft.Common.CheckBox",
            "label": "Assign Reader Role During Deployment",
            "toolTip": "When selected, the deployment grants the function managed identity Reader on each selected subscription.",
            "defaultValue": true
          }
        ]
      },
      {
        "name": "confluence",
        "label": "Confluence",
        "elements": [
          {
            "name": "confluenceHelp",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "Info",
              "text": "Provide the Confluence page and the credentials used for Basic authentication. This deployment currently requires both a username or email and an API token to upload the generated JSON, HLD, and MLD attachments."
            }
          },
          {
            "name": "confluenceBaseUrl",
            "type": "Microsoft.Common.TextBox",
            "label": "Confluence Base URL",
            "defaultValue": "https://yourcompany.atlassian.net",
            "toolTip": "Base URL of your Confluence site. Values with or without /wiki are accepted.",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^https://.+$",
                  "message": "Enter a valid HTTPS URL."
                }
              ]
            }
          },
          {
            "name": "confluenceUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Confluence Username or Email",
            "toolTip": "Required together with the API token because this deployment uses Basic authentication for Confluence.",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^.+$",
                  "message": "Enter the Confluence username or email."
                }
              ]
            }
          },
          {
            "name": "confluenceApiToken",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Confluence API Token",
              "confirmPassword": "Confirm API Token"
            },
            "toolTip": "API token used for Confluence REST API authentication.",
            "constraints": {
              "required": true,
              "regex": "^[\\s\\S]{12,}$",
              "validationMessage": "Use an API token with at least 12 characters."
            },
            "options": {
              "hideConfirmation": false
            }
          },
          {
            "name": "confluencePageId",
            "type": "Microsoft.Common.TextBox",
            "label": "Confluence Page ID",
            "toolTip": "Identifier of the Confluence page that will receive generated attachments.",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[A-Za-z0-9-]+$",
                  "message": "Enter a valid page ID."
                }
              ]
            }
          },
          {
            "name": "confluenceAttachmentPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Attachment Prefix",
            "defaultValue": "cloudnetdraw-topology",
            "toolTip": "Prefix used to name the JSON, HLD, and MLD attachments.",
            "constraints": {
              "required": true,
              "validations": [
                {
                  "regex": "^[A-Za-z0-9._-]{3,80}$",
                  "message": "Use 3-80 letters, numbers, dots, underscores, or hyphens."
                }
              ]
            }
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "functionAppName": "[steps('deployment').functionAppName]",
      "storageAccountName": "[steps('deployment').storageAccount.name]",
      "resourceGroup": "[steps('deployment').storageAccount.resourceGroup]",
      "storageAccountSkuName": "[steps('deployment').storageAccount.type]",
      "storageAccountKind": "StorageV2",
      "newOrExisting": "[steps('deployment').storageAccount.newOrExisting]",
      "containerName": "[steps('deployment').containerName]",
      "deploymentContainerName": "functionpackage",
      "instanceMemoryMB": "[steps('scale').instanceMemoryMB]",
      "maximumInstanceCount": "[steps('scale').maximumInstanceCount]",
      "runtimeName": "python",
      "runtimeVersion": "[steps('scale').runtimeVersion]",
      "selectedSubscriptionIds": "[steps('access').selectedSubscriptionIds]",
      "grantReaderToSelectedSubscriptions": "[steps('access').grantReaderToSelectedSubscriptions]",
      "outputMode": "confluence",
      "confluenceBaseUrl": "[steps('confluence').confluenceBaseUrl]",
      "confluenceUsername": "[steps('confluence').confluenceUsername]",
      "confluenceApiToken": "[steps('confluence').confluenceApiToken]",
      "confluencePageId": "[steps('confluence').confluencePageId]",
      "confluenceAttachmentPrefix": "[steps('confluence').confluenceAttachmentPrefix]"
    }
  }
}
